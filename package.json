{
  "name": "google-tasks-mcp",
  "version": "0.1.0",
  "description": "MCP server for Google Tasks with full task-list CRUD and a change-harvesting diff tool. One auth command, then npx-runnable anywhere.",
  "type": "module",
  "bin": {
    "google-tasks-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "google-tasks",
    "tasks",
    "todo",
    "claude",
    "llm",
    "agent"
  ],
  "author": "Alexander 'Lex' Yermakov (https://github.com/justerlex)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justerlex/google-tasks-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/justerlex/google-tasks-mcp/issues"
  },
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "googleapis": "^173.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
